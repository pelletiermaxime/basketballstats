{
  "name": "basketballstats",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "turbo run dev:nuxt dev:convex --ui=tui",
    "dev:nuxt": "nuxt dev --dotenv .env.local",
    "dev:convex": "convex dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
