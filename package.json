    "better-convex-nuxt": "^0.3.4",
    "convex": "^1.34.1",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "eslint": "^10.1.0",
    "turbo": "^2.8.21",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.29.3"
